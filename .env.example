# =============================================================================
# Grievance AI System — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values marked with CHANGE_ME.
# Lines starting with # are comments and are ignored.
# =============================================================================


# -----------------------------------------------------------------------------
# PostgreSQL  (used by docker-compose and all services via DATABASE_URL)
# -----------------------------------------------------------------------------

# Credentials used by the docker-compose postgres container
POSTGRES_USER=grievance
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=grievance_db

# Full connection URL consumed by SQLAlchemy (sync driver for Alembic/scripts)
# Format: postgresql://<user>:<password>@<host>:<port>/<db>
# Note: the postgres container is mapped to host port 5433 in docker-compose.yml
DATABASE_URL=postgresql://grievance:CHANGE_ME@localhost:5433/grievance_db

# Redis connection (used for API key / auth caching)
REDIS_URL=redis://localhost:6379/0

# How long (seconds) an authenticated identity is cached in Redis
# Default: 300 (5 minutes). Lower values mean faster revocation propagation.
AUTH_CACHE_TTL_SECONDS=300


# -----------------------------------------------------------------------------
# RabbitMQ  (message broker for the processing pipeline)
# -----------------------------------------------------------------------------

# Credentials used by the docker-compose rabbitmq container
RABBITMQ_DEFAULT_USER=sentiment
RABBITMQ_DEFAULT_PASS=password

# Full AMQP URL consumed by all worker services
# Must match RABBITMQ_DEFAULT_USER / RABBITMQ_DEFAULT_PASS above
RABBIT_URL=amqp://sentiment:password@localhost:5672/


# -----------------------------------------------------------------------------
# JWT Authentication  (api-gateway + auth_service)
# -----------------------------------------------------------------------------

# Secret key used to sign and verify JWTs.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME

# Signing algorithm — HS256 is the default and recommended for single-service setups
JWT_ALGORITHM=HS256

# How long (minutes) an access token remains valid
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# These values are embedded in every token as the `iss` and `aud` claims.
# Keep them consistent across all services.
JWT_ISSUER=grievance-auth-service
JWT_AUDIENCE=grievance-api


# -----------------------------------------------------------------------------
# API Key Encryption  (auth_service)
# -----------------------------------------------------------------------------

# Fernet symmetric key used to encrypt stored API keys.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If left empty, API key encryption is disabled (not recommended for production).
API_KEY_ENCRYPTION_SECRET=CHANGE_ME


# -----------------------------------------------------------------------------
# Cloudflare R2 Object Storage  (audio-service + api-gateway)
# -----------------------------------------------------------------------------
# R2 is used to store uploaded audio files and the converted WAV files.
# Create a bucket in the Cloudflare dashboard and generate an API token with
# Object Read & Write permissions.

R2_ACCOUNT_ID=CHANGE_ME
R2_ACCESS_KEY_ID=CHANGE_ME
R2_SECRET_ACCESS_KEY=CHANGE_ME
R2_BUCKET=grievance-audio
R2_PUBLIC_DOMAIN=CHANGE_ME
# URL template used to build public links to stored objects
R2_URL_FORMAT=https://{bucket}.{public_domain}/{key}


# -----------------------------------------------------------------------------
# Translation Service
# -----------------------------------------------------------------------------

# --- Option A: OpenAI (recommended for production) ---
# If set, the translation service will use the OpenAI API.
OPENAI_API_KEY=

# --- Option B: Ollama (local / self-hosted) ---
# If OPENAI_API_KEY is empty, the translation service falls back to Ollama.
# Set this to the model tag you have pulled locally, e.g. llama3.1:latest
TRANSLATION_MODEL=llama3.1:latest


# -----------------------------------------------------------------------------
# ASR (Automatic Speech Recognition) Service
# -----------------------------------------------------------------------------

# Short-audio model name (used for clips shorter than ~30 s)
SHORT_ASR_MODEL=omniASR_LLM_1B_v2

# Long-audio model name (used for longer recordings)
LONG_ASR_MODEL=omniASR_LLM_Unlimited_300M_v2

# Local directories where model weights are cached.
# Paths are relative to the services/asr-service/ directory.
SHORT_ASR_MODEL_CACHE_DIR=model_cache/short_asr
LONG_ASR_MODEL_CACHE_DIR=model_cache/long_asr


# -----------------------------------------------------------------------------
# API Gateway
# -----------------------------------------------------------------------------

# Host and port the uvicorn server binds to
HOST=0.0.0.0
PORT=8000
